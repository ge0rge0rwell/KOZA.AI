# KOZA ortam değişkenleri — tümü OPSİYONEL.
# Hiçbiri yoksa uygulama yerel modda (localStorage + çevrimdışı üretici) tam çalışır.

# Firebase (bulut eşitleme + gerçek topluluk)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# OpenRouter (yapay zekâ üretimi)
VITE_OPENROUTER_API_KEY=
# Opsiyonel model override (vars.: google/gemma-3-27b-it:free)
VITE_OPENROUTER_MODEL=

# Google Analytics (opsiyonel)
VITE_GA_MEASUREMENT_ID=
